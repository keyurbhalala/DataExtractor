# Copy this file to .streamlit/secrets.toml for local development, or paste
# its contents into your Streamlit Community Cloud app's Settings -> Secrets.
#
# Never commit a real .streamlit/secrets.toml file -- it's already covered by
# .gitignore in this repo.
#
# You only need to set the key for whichever provider(s) you plan to use --
# both are optional as long as you're willing to paste a key into the
# sidebar at runtime instead.

ANTHROPIC_API_KEY = "sk-ant-api03-your-key-here"
GEMINI_API_KEY = "your-gemini-key-here"
